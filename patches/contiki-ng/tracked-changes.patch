diff --git a/os/net/routing/rpl-lite/rpl-mrhof.c b/os/net/routing/rpl-lite/rpl-mrhof.c
index 79c06d4..a78701f 100644
--- a/os/net/routing/rpl-lite/rpl-mrhof.c
+++ b/os/net/routing/rpl-lite/rpl-mrhof.c
@@ -48,6 +48,7 @@
 #include "net/routing/rpl-lite/rpl.h"
 #include "net/nbr-table.h"
 #include "net/link-stats.h"
+#include <string.h>
 
 /* Log configuration */
 #include "sys/log.h"
@@ -103,10 +104,460 @@
  * this neighbor regardless of RANK_THRESHOLD. */
 #define TIME_THRESHOLD (10 * 60 * CLOCK_SECOND)
 
+static int nbr_is_acceptable_parent(rpl_nbr_t *nbr);
+
+#ifdef RPL_EXPERIMENTAL_MRHOF
+#define RPL_EXPERIMENTAL_MRHOF_ENABLED RPL_EXPERIMENTAL_MRHOF
+#else
+#define RPL_EXPERIMENTAL_MRHOF_ENABLED 0
+#endif
+
+#if RPL_EXPERIMENTAL_MRHOF_ENABLED
+#define EXP_K_ACTIVE 6
+#define EXP_S_STANDBY 12
+#define EXP_T_DEAD (30 * CLOCK_SECOND)
+#define EXP_MARGIN_RANK 1
+#define EXP_ALPHA_TREND 6553
+#define EXP_BETA_HF 13107
+#define EXP_ETX_STEP MAX(1, LINK_STATS_ETX_DIVISOR / 20)
+/* Align hysteresis semantics with vanilla MRHOF:
+ * - rank hysteresis: RANK_THRESHOLD (default 1.5 ETX) */
+#define EXP_HYST_STEPS ((RANK_THRESHOLD + EXP_ETX_STEP - 1) / EXP_ETX_STEP)
+/* - time hysteresis: TIME_THRESHOLD (default 10 minutes) */
+#define EXP_TIME_THRESHOLD TIME_THRESHOLD
+#define EXP_T_GOOD_MAX (2 * LINK_STATS_ETX_DIVISOR)
+#define EXP_H_GOOD_MAX (LINK_STATS_ETX_DIVISOR / 4)
+
+typedef struct {
+  rpl_nbr_t *nbr;
+  uint16_t trend_etx;
+  uint16_t hf;
+  uint16_t path_steps;
+  clock_time_t last_seen;
+  uint8_t used;
+  uint8_t etx_inited;
+  uint8_t seen;
+  uint8_t feasible;
+} exp_nbr_state_t;
+
+typedef struct {
+  rpl_nbr_t *nbr;
+  uint16_t metric_steps;
+  uint8_t used;
+} exp_entry_t;
+
+static exp_nbr_state_t exp_states[NBR_TABLE_MAX_NEIGHBORS];
+static exp_entry_t exp_active[EXP_K_ACTIVE];
+static exp_entry_t exp_standby[EXP_S_STANDBY];
+static rpl_nbr_t *exp_pending_parent;
+static clock_time_t exp_pending_since;
+static rpl_nbr_t *exp_cached_parent;
+static uint8_t exp_cache_valid;
+
+static uint16_t
+exp_abs_diff_u16(uint16_t a, uint16_t b)
+{
+  return a >= b ? a - b : b - a;
+}
+
+static uint16_t
+exp_saturating_add_u16(uint16_t a, uint16_t b)
+{
+  uint32_t sum = (uint32_t)a + b;
+  return sum > 0xffff ? 0xffff : (uint16_t)sum;
+}
+
+static uint16_t
+exp_ewma_q0_16(uint16_t prev, uint16_t x, uint16_t a_q0_16)
+{
+  uint32_t a = a_q0_16;
+  uint32_t one_minus = 65535 - a;
+  uint32_t y = ((one_minus * prev) + (a * x) + 32768) >> 16;
+  return (uint16_t)y;
+}
+
+static void
+exp_entry_clear(exp_entry_t *e)
+{
+  e->nbr = NULL;
+  e->metric_steps = 0xffff;
+  e->used = 0;
+}
+
+static void
+exp_clear_entries(exp_entry_t *list, uint16_t len)
+{
+  uint16_t i;
+  for(i = 0; i < len; i++) {
+    exp_entry_clear(&list[i]);
+  }
+}
+
+static void
+exp_reset_state(void)
+{
+  memset(exp_states, 0, sizeof(exp_states));
+  exp_clear_entries(exp_active, EXP_K_ACTIVE);
+  exp_clear_entries(exp_standby, EXP_S_STANDBY);
+  exp_pending_parent = NULL;
+  exp_pending_since = 0;
+  exp_cached_parent = NULL;
+  exp_cache_valid = 0;
+}
+
+static exp_nbr_state_t *
+exp_find_state(rpl_nbr_t *nbr)
+{
+  uint16_t i;
+  for(i = 0; i < NBR_TABLE_MAX_NEIGHBORS; i++) {
+    if(exp_states[i].used && exp_states[i].nbr == nbr) {
+      return &exp_states[i];
+    }
+  }
+  return NULL;
+}
+
+static exp_nbr_state_t *
+exp_find_or_alloc_state(rpl_nbr_t *nbr)
+{
+  uint16_t i;
+  exp_nbr_state_t *st = exp_find_state(nbr);
+  if(st != NULL) {
+    return st;
+  }
+
+  for(i = 0; i < NBR_TABLE_MAX_NEIGHBORS; i++) {
+    if(!exp_states[i].used) {
+      exp_states[i].used = 1;
+      exp_states[i].nbr = nbr;
+      exp_states[i].trend_etx = LINK_STATS_ETX_DIVISOR;
+      exp_states[i].hf = 0;
+      exp_states[i].path_steps = 0xffff;
+      exp_states[i].last_seen = 0;
+      exp_states[i].etx_inited = 0;
+      exp_states[i].seen = 0;
+      exp_states[i].feasible = 0;
+      return &exp_states[i];
+    }
+  }
+  return NULL;
+}
+
+static void
+exp_remove_from_entries(exp_entry_t *list, uint16_t len, rpl_nbr_t *nbr)
+{
+  uint16_t i;
+  for(i = 0; i < len; i++) {
+    if(list[i].used && list[i].nbr == nbr) {
+      exp_entry_clear(&list[i]);
+    }
+  }
+}
+
+static uint8_t
+exp_upsert_bounded(exp_entry_t *list, uint16_t len, rpl_nbr_t *nbr, uint16_t metric)
+{
+  uint16_t i;
+  uint16_t worst_i = 0;
+  uint16_t worst_m = 0;
+
+  for(i = 0; i < len; i++) {
+    if(list[i].used && list[i].nbr == nbr) {
+      list[i].metric_steps = metric;
+      return 1;
+    }
+  }
+
+  for(i = 0; i < len; i++) {
+    if(!list[i].used) {
+      list[i].used = 1;
+      list[i].nbr = nbr;
+      list[i].metric_steps = metric;
+      return 1;
+    }
+  }
+
+  for(i = 0; i < len; i++) {
+    if(list[i].used && list[i].metric_steps >= worst_m) {
+      worst_m = list[i].metric_steps;
+      worst_i = i;
+    }
+  }
+
+  if(metric < worst_m) {
+    list[worst_i].used = 1;
+    list[worst_i].nbr = nbr;
+    list[worst_i].metric_steps = metric;
+    return 1;
+  }
+
+  return 0;
+}
+
+static uint16_t
+exp_link_steps_from_etx(uint16_t etx)
+{
+  return etx / EXP_ETX_STEP;
+}
+
+static uint16_t
+exp_metric_steps(exp_nbr_state_t *st)
+{
+  return exp_saturating_add_u16(st->path_steps, exp_link_steps_from_etx(st->trend_etx));
+}
+
+static uint8_t
+exp_hard_gate_ok(exp_nbr_state_t *st, clock_time_t now)
+{
+  uint32_t age;
+  uint32_t parent_rank;
+
+  if(st == NULL || !st->used || st->nbr == NULL) {
+    return 0;
+  }
+
+  if(st->last_seen != 0) {
+    age = (uint32_t)(now - st->last_seen);
+    if(age > EXP_T_DEAD) {
+      return 0;
+    }
+  }
+
+  parent_rank = (uint32_t)st->nbr->rank + EXP_MARGIN_RANK;
+  if(parent_rank >= curr_instance.dag.rank) {
+    return 0;
+  }
+
+  return nbr_is_acceptable_parent(st->nbr);
+}
+
+static uint8_t
+exp_good_gate_ok(exp_nbr_state_t *st)
+{
+  return st->trend_etx <= EXP_T_GOOD_MAX && st->hf <= EXP_H_GOOD_MAX;
+}
+
+static void
+exp_sync_neighbors(clock_time_t now)
+{
+  uint16_t i;
+  uint16_t rank_scale = MAX(curr_instance.min_hoprankinc, 1);
+  rpl_nbr_t *nbr;
+
+  for(i = 0; i < NBR_TABLE_MAX_NEIGHBORS; i++) {
+    if(exp_states[i].used) {
+      exp_states[i].seen = 0;
+      exp_states[i].feasible = 0;
+    }
+  }
+
+  for(nbr = nbr_table_head(rpl_neighbors); nbr != NULL; nbr = nbr_table_next(rpl_neighbors, nbr)) {
+    const struct link_stats *stats;
+    exp_nbr_state_t *st = exp_find_or_alloc_state(nbr);
+
+    if(st == NULL) {
+      continue;
+    }
+
+    st->nbr = nbr;
+    st->seen = 1;
+    st->path_steps = nbr->rank / rank_scale;
+
+    stats = rpl_neighbor_get_link_stats(nbr);
+    if(stats != NULL) {
+      st->last_seen = now;
+    }
+    if(stats != NULL && link_stats_is_fresh(stats)) {
+      uint16_t x = stats->etx;
+      if(!st->etx_inited) {
+        st->trend_etx = x;
+        st->hf = 0;
+        st->etx_inited = 1;
+      } else {
+        st->trend_etx = exp_ewma_q0_16(st->trend_etx, x, EXP_ALPHA_TREND);
+        st->hf = exp_ewma_q0_16(st->hf, exp_abs_diff_u16(x, st->trend_etx), EXP_BETA_HF);
+      }
+    }
+  }
+
+  for(i = 0; i < NBR_TABLE_MAX_NEIGHBORS; i++) {
+    if(exp_states[i].used && !exp_states[i].seen) {
+      exp_remove_from_entries(exp_active, EXP_K_ACTIVE, exp_states[i].nbr);
+      exp_remove_from_entries(exp_standby, EXP_S_STANDBY, exp_states[i].nbr);
+      if(exp_pending_parent == exp_states[i].nbr) {
+        exp_pending_parent = NULL;
+        exp_pending_since = 0;
+      }
+      if(exp_cached_parent == exp_states[i].nbr) {
+        exp_cached_parent = NULL;
+      }
+      memset(&exp_states[i], 0, sizeof(exp_states[i]));
+    }
+  }
+}
+
+static void
+exp_rebuild_membership(clock_time_t now)
+{
+  uint16_t i;
+
+  exp_clear_entries(exp_active, EXP_K_ACTIVE);
+  exp_clear_entries(exp_standby, EXP_S_STANDBY);
+
+  for(i = 0; i < NBR_TABLE_MAX_NEIGHBORS; i++) {
+    exp_nbr_state_t *st = &exp_states[i];
+    uint16_t metric;
+
+    if(!st->used) {
+      continue;
+    }
+
+    st->feasible = 0;
+    if(!exp_hard_gate_ok(st, now)) {
+      continue;
+    }
+
+    metric = exp_metric_steps(st);
+    if(exp_good_gate_ok(st)) {
+      uint8_t in_active = exp_upsert_bounded(exp_active, EXP_K_ACTIVE, st->nbr, metric);
+      uint8_t in_standby = 0;
+      if(!in_active) {
+        in_standby = exp_upsert_bounded(exp_standby, EXP_S_STANDBY, st->nbr, metric);
+      }
+      st->feasible = !(in_active || in_standby);
+    } else {
+      st->feasible = 1;
+    }
+  }
+}
+
+static uint8_t
+exp_choose_best_from_entries(exp_entry_t *list, uint16_t len, clock_time_t now, rpl_nbr_t **best_nbr, uint16_t *best_metric)
+{
+  uint16_t i;
+  uint8_t found = 0;
+
+  for(i = 0; i < len; i++) {
+    exp_nbr_state_t *st;
+    if(!list[i].used || list[i].nbr == NULL) {
+      continue;
+    }
+    st = exp_find_state(list[i].nbr);
+    if(!exp_hard_gate_ok(st, now)) {
+      continue;
+    }
+    if(!found || list[i].metric_steps < *best_metric) {
+      found = 1;
+      *best_nbr = list[i].nbr;
+      *best_metric = list[i].metric_steps;
+    }
+  }
+
+  return found;
+}
+
+static uint8_t
+exp_choose_best_from_feasible(clock_time_t now, rpl_nbr_t **best_nbr, uint16_t *best_metric)
+{
+  uint16_t i;
+  uint8_t found = 0;
+
+  for(i = 0; i < NBR_TABLE_MAX_NEIGHBORS; i++) {
+    exp_nbr_state_t *st = &exp_states[i];
+    uint16_t metric;
+    if(!st->used || !st->feasible) {
+      continue;
+    }
+    if(!exp_hard_gate_ok(st, now)) {
+      continue;
+    }
+    metric = exp_metric_steps(st);
+    if(!found || metric < *best_metric) {
+      found = 1;
+      *best_nbr = st->nbr;
+      *best_metric = metric;
+    }
+  }
+
+  return found;
+}
+
+static rpl_nbr_t *
+exp_select_parent(clock_time_t now)
+{
+  rpl_nbr_t *best_nbr = NULL;
+  uint16_t best_metric = 0xffff;
+  uint8_t found = 0;
+  rpl_nbr_t *cur = curr_instance.dag.preferred_parent;
+  uint16_t cur_metric = 0xffff;
+  uint8_t cur_usable = 0;
+
+  exp_sync_neighbors(now);
+  exp_rebuild_membership(now);
+
+  found = exp_choose_best_from_entries(exp_active, EXP_K_ACTIVE, now, &best_nbr, &best_metric);
+  if(!found) {
+    found = exp_choose_best_from_entries(exp_standby, EXP_S_STANDBY, now, &best_nbr, &best_metric);
+  }
+  if(!found) {
+    found = exp_choose_best_from_feasible(now, &best_nbr, &best_metric);
+  }
+
+  if(!found || best_nbr == NULL) {
+    exp_pending_parent = NULL;
+    exp_pending_since = 0;
+    return NULL;
+  }
